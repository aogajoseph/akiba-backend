// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  deposit
  withdrawal
  fee
}

enum TransactionStatus {
  initiated
  pending
  pending_approval
  approved
  rejected
  completed
  failed
  reversed
}

enum TransactionSource {
  mpesa
  mpesa_paybill
  mpesa_stk
  card
  bank_transfer
  system_fee
}

enum NotificationType {
  deposit_completed
  withdrawal_requested
  withdrawal_approved
  withdrawal_rejected
  withdrawal_completed
  space_updated
  space_deleted
}

model User {
  id        String   @id @default(uuid())
  name      String?
  phone     String?  @unique
  email     String?  @unique
  createdAt DateTime @default(now())

  spaces              SpaceMember[]
  transactions        Transaction[]
  withdrawalApprovals WithdrawalApproval[]
  messages            Message[]
  messageReactions    MessageReaction[]
  notificationsAuthored  Notification[]          @relation("NotificationActor")
  notificationRecipients NotificationRecipient[] @relation("NotificationRecipient")
  devices             Device[]
}

model Space {
  id                String   @id @default(uuid())
  name              String
  description       String?
  imageUrl          String?

  targetAmount      Float?
  deadline          DateTime?

  paybillNumber     String?
  accountNumber     String? @unique
  approvalThreshold Int     @default(2)

  createdAt         DateTime @default(now())
  createdById       String

  members      SpaceMember[]
  transactions Transaction[]
  messages     Message[]
}

model SpaceMember {
  id        String   @id @default(uuid())
  spaceId   String
  userId    String
  role      String   // "admin" | "member"
  createdAt DateTime @default(now())

  space Space @relation(fields: [spaceId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([spaceId, userId])
}

model Transaction {
  id            String            @id @default(uuid())
  spaceId       String
  userId        String?
  type          TransactionType
  status        TransactionStatus
  amount        Decimal           @db.Decimal(18, 2)
  reference     String            @unique
  source        TransactionSource
  phoneNumber   String?
  externalName  String?
  recipientPhoneNumber String?
  recipientName String?
  description   String?
  destination   String?
  createdAt     DateTime          @default(now())

  space Space @relation(fields: [spaceId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  approvals WithdrawalApproval[]
}

model Notification {
  id            String           @id @default(uuid())
  eventKey      String           @unique
  type          NotificationType
  actorId       String?
  spaceId       String?
  transactionId String?
  title         String
  body          String
  metadata      Json?
  createdAt     DateTime         @default(now())

  actor      User?                   @relation("NotificationActor", fields: [actorId], references: [id])
  recipients NotificationRecipient[]

  @@index([spaceId, createdAt])
  @@index([transactionId])
  @@index([type, createdAt])
}

model NotificationRecipient {
  id             String       @id @default(uuid())
  notificationId String
  userId         String
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  notification Notification @relation(fields: [notificationId], references: [id])
  user         User         @relation("NotificationRecipient", fields: [userId], references: [id])

  @@unique([notificationId, userId])
  @@index([userId, isRead, createdAt])
}

model Message {
  id        String   @id @default(uuid())
  spaceId    String
  userId     String
  text       String   @default("")
  replyToId  String?
  status     String   @default("sent")
  createdAt  DateTime @default(now())

  space       Space               @relation(fields: [spaceId], references: [id])
  user        User                @relation(fields: [userId], references: [id])
  replyTo     Message?            @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     Message[]           @relation("MessageReplies")
  attachments MessageAttachment[]
  reactions   MessageReaction[]

  @@index([spaceId, createdAt])
  @@index([userId, createdAt])
  @@index([replyToId])
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  type      String
  url       String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])

  @@index([messageId, createdAt])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@index([messageId, createdAt])
  @@index([userId, createdAt])
}

model Device {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model WebhookEvent {
  id           String    @id @default(uuid())
  provider     String
  eventType    String
  reference    String?
  spaceId      String?
  status       String
  payload      Json
  errorMessage String?
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?
}

model WithdrawalApproval {
  id            String   @id @default(uuid())
  transactionId String
  adminId       String
  status        String   // approved | rejected
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])
  admin       User        @relation(fields: [adminId], references: [id])

  @@unique([transactionId, adminId])
}
